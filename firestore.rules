rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection contains app user profiles and their roles (primary/admin/viewer)
    match /admins/{adminId} {
      allow read: if request.auth != null;
      // Allow creating your own admin doc after signup
      allow create: if request.auth != null && request.auth.uid == adminId;
      // Allow updating own profile (but do NOT allow changing role here unless primary)
      allow update: if request.auth != null && request.auth.uid == adminId && !(request.resource.data.role != resource.data.role);
      // Disallow client-side deletes of admin docs - manage via server or console
      allow delete: if false;
    }

    // Rents collection example
    match /rents/{rentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && canEditResource();
      allow delete: if request.auth != null && isPrimaryAdmin();
    }

    // Generic helper functions
    function isPrimaryAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'primary';
    }

    function canEditResource() {
      return request.auth != null &&
        (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['primary', 'admin']);
    }

    // Add other collections with similar patterns: stocks, sales, land_records, expenses, transactions

  }
}
